{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost",
  "DailyReset": {
    // Platform-wide cutover hour in UTC (0–23). Default: 3 = 03:00 UTC.
    // 03:00 UTC ≈ 10 PM EST / 7 PM PST — after typical dinner service.
    // Override per environment via environment variables or appsettings.{Env}.json.
    "CutoverHourUtc": 3
  }
}
